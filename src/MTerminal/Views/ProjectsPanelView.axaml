<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MTerminal.ViewModels"
             xmlns:m="using:MTerminal.Models"
             x:Class="MTerminal.Views.ProjectsPanelView"
             x:DataType="vm:ProjectsPanelViewModel"
             Background="#16162a">

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="14,10"
                BorderBrush="#2a2a4a" BorderThickness="0,0,0,1">
            <TextBlock Text="PROJECTS" FontWeight="SemiBold" FontSize="11"
                       Foreground="#6070a0" LetterSpacing="1.5" />
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="8" BorderBrush="#2a2a4a" BorderThickness="0,1,0,0">
            <Button Content="+ Add Project"
                    Command="{Binding AddProjectCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Background="#1e1e3a"
                    Foreground="#8090b0"
                    CornerRadius="6"
                    Padding="8,6"
                    FontSize="12"
                    BorderThickness="1"
                    BorderBrush="#2a2a4a"
                    Cursor="Hand" />
        </Border>

        <ListBox x:Name="ProjectList"
                 ItemsSource="{Binding Projects}"
                 SelectedItem="{Binding SelectedProject}"
                 Background="Transparent"
                 Margin="0,2">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="10,6" />
                    <Setter Property="Margin" Value="4,1" />
                    <Setter Property="CornerRadius" Value="6" />
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="#2a2a4a" />
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="#222240" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="m:Project">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="&#x2715;"
                                FontSize="10"
                                Background="Transparent"
                                Foreground="#505070"
                                Padding="4,2"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding #ProjectList.((vm:ProjectsPanelViewModel)DataContext).RemoveProjectCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Remove project" />
                        <StackPanel Spacing="1">
                            <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                       FontSize="12" Foreground="#c0c8e0" />
                            <TextBlock Text="{Binding DirectoryPath}"
                                       FontSize="10"
                                       Foreground="#505070"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
