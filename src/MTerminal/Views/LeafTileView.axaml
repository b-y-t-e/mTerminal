<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MTerminal.ViewModels"
             xmlns:m="using:MTerminal.Models"
             x:Class="MTerminal.Views.LeafTileView"
             x:DataType="vm:LeafTileNodeViewModel">

    <Border BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="{DynamicResource BorderThin}"
            CornerRadius="{DynamicResource RadiusSm}"
            ClipToBounds="True">
        <DockPanel>
            <!-- Tile toolbar -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource BgSurface}"
                    Padding="6,0"
                    Height="26">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="1">
                        <Button Classes="tile-btn" ToolTip.Tip="Split tile">
                            <Button.Content>
                                <TextBlock Text="+" FontSize="{DynamicResource FontMd}" FontWeight="Bold" />
                            </Button.Content>
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuItem Header="Split Right"
                                              Command="{Binding SplitVerticalCommand}" />
                                    <MenuItem Header="Split Down"
                                              Command="{Binding SplitHorizontalCommand}" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                        <Button Classes="tile-btn"
                                Command="{Binding CloseCommand}"
                                ToolTip.Tip="Close tile">
                            <TextBlock Text="x" FontSize="{DynamicResource FontSm}" />
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="TileNameLabel"
                               Text="{Binding TileName}"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource FontXs}"
                               Foreground="{DynamicResource TextFaint}"
                               Margin="2,0"
                               Cursor="Hand"
                               DoubleTapped="TileNameLabel_DoubleTapped" />
                    <TextBox x:Name="TileNameEditor"
                             Text="{Binding TileName}"
                             IsVisible="False"
                             Classes="inline-editor"
                             LostFocus="TileNameEditor_Confirm"
                             KeyDown="TileNameEditor_KeyDown" />
                </DockPanel>
            </Border>

            <!-- Content type chooser: shown when tile is empty -->
            <StackPanel x:Name="ContentChooser"
                        IsVisible="False"
                        Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock Text="Select tile type"
                           HorizontalAlignment="Center"
                           FontSize="{DynamicResource FontSm}"
                           Foreground="{DynamicResource TextFaint}"
                           Margin="0,0,0,4" />
                <Button Classes="outlined"
                        Command="{Binding SelectContentTypeCommand}"
                        CommandParameter="{x:Static m:TileContentType.Terminal}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center">
                    Terminal
                </Button>
                <Button Classes="outlined"
                        Command="{Binding SelectContentTypeCommand}"
                        CommandParameter="{x:Static vm:TileContentTypeValues.Note}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center">
                    Note
                </Button>
            </StackPanel>

            <!-- Content area: managed in code-behind -->
            <Panel x:Name="ContentHost" />
        </DockPanel>
    </Border>
</UserControl>
