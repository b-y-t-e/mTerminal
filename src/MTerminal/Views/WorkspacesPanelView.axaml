<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MTerminal.ViewModels"
             xmlns:m="using:MTerminal.Models"
             x:Class="MTerminal.Views.WorkspacesPanelView"
             x:DataType="vm:WorkspacesPanelViewModel"
             Background="{DynamicResource BgSurface}">

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="14,10"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="{DynamicResource BorderBottom}">
            <TextBlock Text="WORKSPACES" Classes="section" Margin="0" />
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="8"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="{DynamicResource BorderTop}">
            <Button Content="+ Add Workspace"
                    Classes="outlined"
                    Command="{Binding AddWorkspaceCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center" />
        </Border>

        <ListBox x:Name="WorkspaceList"
                 ItemsSource="{Binding Workspaces}"
                 SelectedItem="{Binding SelectedWorkspace}"
                 Background="Transparent"
                 Margin="0,2">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="10,6" />
                    <Setter Property="Margin" Value="4,1" />
                    <Setter Property="CornerRadius" Value="{DynamicResource RadiusLg}" />
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource InteractiveHover}" />
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource InteractiveHover}" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="m:Workspace">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="x" Classes="ghost"
                                FontSize="{DynamicResource FontXs}"
                                Command="{Binding #WorkspaceList.((vm:WorkspacesPanelViewModel)DataContext).RemoveWorkspaceCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Remove workspace" />
                        <StackPanel Spacing="1">
                            <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                       FontSize="{DynamicResource FontMd}"
                                       Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock Text="{Binding DirectoryPath}" Classes="caption"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
