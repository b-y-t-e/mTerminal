<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MTerminal.ViewModels"
        xmlns:views="using:MTerminal.Views"
        x:Class="MTerminal.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MTerminal"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <DockPanel>
        <!-- Top bar -->
        <Border DockPanel.Dock="Top"
                Background="#16162a"
                BorderBrush="#2a2a4a"
                BorderThickness="0,0,0,1"
                Padding="4,0"
                Height="38">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="2">
                    <Button Classes="toolbar"
                            Content="&#9776;"
                            FontSize="16"
                            Command="{Binding TogglePanelCommand}"
                            ToolTip.Tip="Toggle Projects Panel" />
                    <TextBlock Text="MTerminal" VerticalAlignment="Center"
                               Foreground="#8088a0"
                               FontWeight="SemiBold" FontSize="13" Margin="8,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2">
                    <Button Classes="toolbar"
                            Content="&#9881;"
                            FontSize="16"
                            Command="{Binding ToggleSettingsCommand}"
                            ToolTip.Tip="Settings" />
                </StackPanel>
                <Panel />
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Panel>
            <SplitView IsPaneOpen="{Binding IsPanelOpen}"
                       DisplayMode="CompactInline"
                       CompactPaneLength="0"
                       OpenPaneLength="240">
                <SplitView.Pane>
                    <views:ProjectsPanelView DataContext="{Binding ProjectsPanel}" />
                </SplitView.Pane>
                <SplitView.Content>
                    <Panel>
                        <ContentControl Content="{Binding CurrentWorkspace}" />
                        <TextBlock Text="Select or add a project to get started"
                                   IsVisible="{Binding CurrentWorkspace, Converter={x:Static ObjectConverters.IsNull}}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   Foreground="#4a4a6a" />
                    </Panel>
                </SplitView.Content>
            </SplitView>

            <!-- Settings flyout -->
            <Border IsVisible="{Binding IsSettingsOpen}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,4,4,0">
                <ContentControl Content="{Binding Settings}" />
            </Border>
        </Panel>
    </DockPanel>
</Window>
