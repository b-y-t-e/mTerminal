<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:mTiles.ViewModels"
             xmlns:m="using:mTiles.Models"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="mTiles.Views.WorkspacesPanelView"
             x:DataType="vm:WorkspacesPanelViewModel"
             Background="{DynamicResource BgSurface}">

    <UserControl.Styles>
        <Style Selector="ScrollViewer.scroll-left">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="*,Auto" ColumnSpacing="0" RowSpacing="0">
                        <ScrollBar Name="PART_VerticalScrollBar" Margin="3, 0, 0, 0" 
                                   Grid.Column="0" Grid.Row="0" Padding="0" 
                                   Orientation="Vertical" />
                        <ScrollContentPresenter Name="PART_ContentPresenter"
                                                Grid.Column="1" Grid.Row="0" 
                                                Background="{TemplateBinding Background}"
                                                Margin="0"
                                                Padding="{TemplateBinding Padding}" />
                        <ScrollBar Name="PART_HorizontalScrollBar" Margin="0"
                                   Grid.Column="1" Grid.Row="1"
                                   Orientation="Horizontal" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Panel>
        <!-- ═══ EXPANDED MODE ═══ -->
        <DockPanel x:Name="ExpandedPanel">
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="2" Margin="8,4,8,6">
                <Button Classes="toolbar"
                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleSettingsCommand}"
                        ToolTip.Tip="Settings">
                    <mi:MaterialIcon Kind="CogOutline" Width="18" Height="18" />
                </Button>
                <Button Classes="toolbar"
                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ApplyUpdateCommand}"
                        ToolTip.Tip="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).UpdateVersion, StringFormat='Update to {0}'}"
                        IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsUpdateAvailable}"
                        Foreground="{DynamicResource AccentDefault}">
                    <mi:MaterialIcon Kind="ArrowUpBoldCircleOutline" Width="18" Height="18" />
                </Button>
            </StackPanel>

            <TextBox DockPanel.Dock="Top"
                     Text="{Binding FilterText, Mode=TwoWay}"
                     PlaceholderText="Filter..."
                     IsVisible="{Binding ShowFilter}"
                     Margin="5,5,5,7"
                     Padding="9,6"
                     FontSize="{DynamicResource FontSm}">
                <TextBox.InnerRightContent>
                    <Button Classes="ghost"
                            Command="{Binding ClearFilterCommand}"
                            IsVisible="{Binding FilterText.Length}"
                            Padding="2" Margin="0,0,2,0"
                            MinWidth="16" MinHeight="16">
                        <mi:MaterialIcon Kind="Close" Width="10" Height="10" />
                    </Button>
                </TextBox.InnerRightContent>
            </TextBox>

            <ScrollViewer Classes="scroll-left"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Margin="1, 0, 0, 0">
                <StackPanel Margin="0">
                    <ItemsControl x:Name="WorkspaceList"
                                  ItemsSource="{Binding FilteredWorkspaces}"
                                  Margin="3, 0 , 4 , 4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:WorkspaceItemViewModel">
                                <Border Classes="workspace-item"
                                        Classes.workspace-item-selected="{Binding IsSelected}"
                                        Padding="10,6"
                                        Margin="2,0 , 2 , 4"
                                        CornerRadius="{DynamicResource RadiusLg}"
                                        Cursor="Hand"
                                        PointerPressed="WorkspaceItem_PointerPressed">
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimary}" />
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal" Spacing="3"
                                                        IsVisible="{Binding BranchName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        VerticalAlignment="Center"
                                                        Margin="6,0,0,0">
                                                <mi:MaterialIcon Kind="SourceBranch" Width="10" Height="10"
                                                                 Foreground="{DynamicResource AccentDefault}" />
                                                <TextBlock Text="{Binding BranchName}"
                                                           FontSize="{DynamicResource FontXs}"
                                                           Foreground="{DynamicResource AccentDefault}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding DirectoryPath}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontSize="{DynamicResource UiFontSizeSm}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Opacity="0.8" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Classes="add-workspace"
                            Command="{Binding AddWorkspaceCommand}"
                            Margin="8,0, 8, 2"
                            HorizontalAlignment="Stretch"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <mi:MaterialIcon Kind="Plus" Width="16" Height="16" />
                            <TextBlock Text="Workspace" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- ═══ COLLAPSED MODE (icon strip) ═══ -->
        <DockPanel x:Name="CollapsedPanel" IsVisible="False">
            <StackPanel DockPanel.Dock="Bottom" Spacing="2" HorizontalAlignment="Center" Margin="0,4,0,6">
                <Button Classes="toolbar"
                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ApplyUpdateCommand}"
                        ToolTip.Tip="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).UpdateVersion, StringFormat='Update to {0}'}"
                        IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsUpdateAvailable}"
                        Foreground="{DynamicResource AccentDefault}"
                        HorizontalAlignment="Center">
                    <mi:MaterialIcon Kind="ArrowUpBoldCircleOutline" Width="16" Height="16" />
                </Button>
                <Button Classes="toolbar"
                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleSettingsCommand}"
                        HorizontalAlignment="Center"
                        ToolTip.Tip="Settings">
                    <mi:MaterialIcon Kind="CogOutline" Width="16" Height="16" />
                </Button>
            </StackPanel>

            <Button DockPanel.Dock="Bottom"
                    Classes="toolbar"
                    Command="{Binding AddWorkspaceCommand}"
                    HorizontalAlignment="Center"
                    Margin="0,2,0,0"
                    ToolTip.Tip="Add Workspace">
                <mi:MaterialIcon Kind="Plus" Width="16" Height="16" />
            </Button>

            <ScrollViewer Classes="scroll-left"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Workspaces}" Margin="0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:WorkspaceItemViewModel">
                            <Border Width="32" Height="32"
                                    Margin="0,2"
                                    CornerRadius="6"
                                    HorizontalAlignment="Center"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    ToolTip.Tip="{Binding Name}"
                                    PointerPressed="CollapsedItem_PointerPressed"
                                    Classes.workspace-icon-selected="{Binding IsSelected}">
                                <TextBlock Text="{Binding Initials}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMuted}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Panel>
</UserControl>
